{
  // Config do Cloudflare Workers para servir o site como ASSETS ESTÁTICOS.
  // Não há "build" de verdade: é um arquivo HTML único. O Worker só serve a pasta.
  "name": "desapego",
  "compatibility_date": "2025-01-01",
  "assets": {
    // Serve SÓ a pasta docs/ (que contém apenas o index.html). Assim nada de
    // interno (CLAUDE.md, memórias, .git) é exposto. Mesma pasta serve o GitHub Pages.
    "directory": "./docs",
    // Se a rota não existir, cai no index.html (página única).
    "not_found_handling": "single-page-application"
  }
}
